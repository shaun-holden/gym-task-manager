# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gym_task_manager

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# SMTP (optional — emails are skipped if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="GymTaskManager" <noreply@gym.com>

# EOD Reminder (24h format, weekdays only)
EOD_REMINDER_TIME=17:00

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Node environment
NODE_ENV=development
