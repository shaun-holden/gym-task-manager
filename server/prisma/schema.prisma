generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum EodItemType {
  TEXT
  CHECKBOX
  NUMBER
  RATING
  DATE
  TIME
  ATTACHMENT
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  EOD_SUBMITTED
  EOD_REMINDER
  URGENT
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users          User[]
  tasks          Task[]
  eodTemplates   EodTemplate[]
  resources      Resource[]
  taskCategories TaskCategoryCustom[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  name           String
  role           Role     @default(EMPLOYEE)
  isActive       Boolean  @default(true) @map("is_active")
  supervisorId   String?  @map("supervisor_id")
  organizationId String?  @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  supervisor   User?  @relation("TeamHierarchy", fields: [supervisorId], references: [id])
  subordinates User[] @relation("TeamHierarchy")

  assignedTasks    Task[] @relation("TaskAssignee")
  createdTasks     Task[] @relation("TaskCreator")
  eodSubmissions   EodSubmission[] @relation("EodEmployee")
  eodSubmittedFor  EodSubmission[] @relation("EodSubmitter")
  createdTemplates EodTemplate[]
  notifications     Notification[]
  resources         Resource[]
  taskCategories    TaskCategoryCustom[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  category       String       @default("OTHER")
  startDate      DateTime?    @map("start_date")
  dueDate        DateTime?    @map("due_date")
  isCompleted    Boolean      @default(false) @map("is_completed")
  completedAt    DateTime?    @map("completed_at")
  notes          String?
  assignedToId   String       @map("assigned_to_id")
  createdById    String       @map("created_by_id")
  organizationId String?      @map("organization_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  assignedTo   User          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy    User          @relation("TaskCreator", fields: [createdById], references: [id])

  @@map("tasks")
}

model EodTemplate {
  id             String   @id @default(uuid())
  title          String
  createdById    String   @map("created_by_id")
  isActive       Boolean  @default(true) @map("is_active")
  organizationId String?  @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  createdBy    User              @relation(fields: [createdById], references: [id])
  items        EodTemplateItem[]
  submissions  EodSubmission[]

  @@map("eod_templates")
}

model EodTemplateItem {
  id         String      @id @default(uuid())
  templateId String      @map("template_id")
  question   String
  sortOrder  Int         @default(0) @map("sort_order")
  type       EodItemType @default(TEXT)
  isRequired Boolean     @default(false) @map("is_required")

  template  EodTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses EodResponse[]

  @@map("eod_template_items")
}

model EodSubmission {
  id            String    @id @default(uuid())
  templateId    String    @map("template_id")
  employeeId    String    @map("employee_id")
  submittedById String?   @map("submitted_by_id")
  date          DateTime  @db.Date
  submittedAt   DateTime? @map("submitted_at")
  notes         String?
  mood          Int?
  createdAt     DateTime  @default(now()) @map("created_at")

  template    EodTemplate   @relation(fields: [templateId], references: [id])
  employee    User          @relation("EodEmployee", fields: [employeeId], references: [id])
  submittedBy User?         @relation("EodSubmitter", fields: [submittedById], references: [id])
  responses   EodResponse[]

  @@unique([templateId, employeeId, date])
  @@map("eod_submissions")
}

model EodResponse {
  id             String   @id @default(uuid())
  submissionId   String   @map("submission_id")
  templateItemId String   @map("template_item_id")
  response       String
  createdAt      DateTime @default(now()) @map("created_at")

  submission   EodSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  templateItem EodTemplateItem @relation(fields: [templateItemId], references: [id])

  @@map("eod_responses")
}

model Resource {
  id             String   @id @default(uuid())
  title          String
  url            String
  description    String?
  category       String?
  organizationId String?  @map("organization_id")
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])

  @@map("resources")
}

model TaskCategoryCustom {
  id             String   @id @default(uuid())
  name           String
  organizationId String?  @map("organization_id")
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])

  @@map("task_categories")
}

model Notification {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  type           NotificationType
  message        String
  isRead         Boolean          @default(false) @map("is_read")
  relatedId      String?          @map("related_id")
  acknowledgedAt DateTime?        @map("acknowledged_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
